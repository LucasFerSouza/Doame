# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente do @doame/web (Next.js)
# Copie para .env.local e preencha com seus valores.
# ─────────────────────────────────────────────────────────────────────────────

# URL base da API NestJS (usada para chamadas server-side e client-side)
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# ID da igreja padrão (deve corresponder ao seed do banco de dados)
NEXT_PUBLIC_IGREJA_ID="igreja-itapetininga-01"
