# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente do doame-api
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA faça commit do .env com dados reais.
# ─────────────────────────────────────────────────────────────────────────────

# Banco de dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/doame"

# JWT — use uma string longa e aleatória em produção
JWT_SECRET="doame_jwt_secret_mvp_2025"

# Expiração do token (1d = 1 dia, 7d = 7 dias)
JWT_EXPIRES_IN="1d"

# Porta da API
PORT=3001

# URL do frontend (usada para configurar CORS)
FRONTEND_URL="http://localhost:3000"
